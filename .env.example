# URL base del backend de Auto Express Hub
# Si el backend corre con docker-compose: http://localhost:3001
# Si el backend corre directo con bun/npm: http://localhost:3000
AUTO_EXPRESS_HUB_API_URL=http://localhost:3001

# Clave secreta para proteger el servidor MCP (cualquier string seguro)
# Se usa como "contraseña" en el formulario de autorización OAuth
MCP_API_KEY=mcp_sk_replace_with_real_key

# Secreto para firmar los JWT de OAuth (cualquier string largo y aleatorio)
# Si no se define, se usa MCP_API_KEY como fallback
OAUTH_JWT_SECRET=oauth_jwt_secret_replace_with_random_string

# (Opcional) Client ID y Client Secret para verificar la identidad del cliente OAuth
# Configuralos en Claude.ai al agregar el conector, y aquí con el mismo valor
OAUTH_CLIENT_ID=auto-express-hub
OAUTH_CLIENT_SECRET=oauth_client_secret_replace_with_real_secret

# Puerto del servidor MCP (default: 3002 para no colisionar con el backend en Docker)
PORT=3002
